#!/usr/bin/env bash
# ============================================================
# Git pre-push hook — Shaadi Mantrana
# Blocks git push if critical/high security vulnerabilities exist or E2E tests fail.
# Installed automatically by: bash scripts/install-git-hooks.sh
# ============================================================

ROOT_DIR="$(git rev-parse --show-toplevel)"
SCRIPT="$ROOT_DIR/scripts/security-audit-fix.sh"
DEVILS_ADVOCATE_FILE="$ROOT_DIR/devils-advocate/risk-assessment.txt"

echo ""
echo "😈 Verifying Devil's Advocate risk assessment..."
if [ ! -f "$DEVILS_ADVOCATE_FILE" ] || [ ! -s "$DEVILS_ADVOCATE_FILE" ]; then
  echo "❌ Push BLOCKED: No Devil's Advocate risk analysis found."
  echo "   Please write a risk statement to: devils-advocate/risk-assessment.txt"
  echo "   containing the most likely failure modes and silent assumptions."
  echo ""
  exit 1
else
  echo "   ----------------------------------------------------------------------"
  echo "   📢 ACTIVE DEVIL'S ADVOCATE STATEMENT:"
  cat "$DEVILS_ADVOCATE_FILE" | sed 's/^/   /g'
  echo "   ----------------------------------------------------------------------"
  echo "✅ Devil's Advocate gate passed."
fi

echo ""
echo "🔐 Running security audit before push..."
echo ""


if [ ! -f "$SCRIPT" ]; then
  echo "⚠ Security script not found at $SCRIPT — skipping security gate"
else
  chmod +x "$SCRIPT"
  # Use --auto-fix: handles both safe fix AND clean reinstall for workspace pin issues
  bash "$SCRIPT" --auto-fix
  STATUS=$?

  if [ $STATUS -ne 0 ]; then
    echo ""
    echo "❌ Push BLOCKED due to unresolved security vulnerabilities."
    echo "   Review the output above and fix manually if needed."
    echo "   Then re-run: git push"
    echo ""
    exit 1
  fi
  echo "✅ Security gate passed."
fi

echo ""
echo "🚀 Running local E2E validation tests..."
echo ""

# Run E2E Playwright tests locally
cd "$ROOT_DIR"
export PATH=$PATH:/usr/local/bin:/opt/homebrew/bin
export GIT_HOOK=true
npm run e2e
E2E_STATUS=$?

if [ $E2E_STATUS -ne 0 ]; then
  echo ""
  echo "❌ Push BLOCKED due to E2E test failures."
  echo "   Please fix failing E2E tests before pushing."
  echo "   Then re-run: git push"
  echo ""
  exit 1
fi

echo ""
echo "✅ Security gate and E2E validation passed — proceeding with push."
exit 0
