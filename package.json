{
  "name": "shaadi-mantra",
  "version": "1.0.0",
  "description": "Shaadi Mantrana - Matrimonial Platform",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && npm install --workspace=frontend && npm install --workspace=backend",
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "start": "npm run start --workspace=backend",
    "build": "npm run build --workspace=frontend && npm run build --workspace=backend",
    "lint": "npm run lint --workspace=frontend && npm run lint --workspace=backend",
    "test": "npm run test --workspace=backend",
    "security:audit": "bash scripts/security-audit-fix.sh",
    "security:fix": "bash scripts/security-audit-fix.sh --fix",
    "prepare": "bash scripts/install-git-hooks.sh >/dev/null 2>&1 || true"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "next": "^15.5.7",
    "serialize-javascript": "^7.0.5",
    "braces": "^3.0.3",
    "postcss": "^8.4.31",
    "micromatch": "^4.0.8",
    "elliptic": "^6.5.7",
    "semver": "^7.5.2",
    "cross-spawn": "^7.0.5",
    "nanoid": "^3.3.3",
    "path-to-regexp": "^0.1.12",
    "cookie": "^0.7.0",
    "tar": "^6.2.3",
    "ip": "^1.1.9",
    "ws": "^8.17.1",
    "undici": "^6.19.2",
    "@tootallnate/once": "^3.0.1",
    "cloudinary": "^2.10.0",
    "swiper": "^12.1.4",
    "@rollup/plugin-terser": "^0.4.4"
  },
  "keywords": [
    "shaadi",
    "mantra",
    "matrimony",
    "monorepo"
  ],
  "author": "IAM-Nitesh",
  "license": "ISC",
  "devDependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "@playwright/test": "^1.40.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/nodemailer": "^6.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3"
  }
}
