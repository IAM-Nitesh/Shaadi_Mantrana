{
  "name": "shaadi-mantra",
  "version": "1.0.0",
  "description": "Shaadi Mantrana - Matrimonial Platform",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && npm install --workspace=frontend && npm install --workspace=backend",
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "start": "npm run start --workspace=backend",
    "build": "npm run build --workspace=frontend && npm run build --workspace=backend",
    "lint": "npm run lint --workspace=frontend && npm run lint --workspace=backend",
    "test": "npm run test --workspace=backend",
    "security:audit": "bash scripts/security-audit-fix.sh",
    "security:fix": "bash scripts/security-audit-fix.sh --fix",
    "prepare": "bash scripts/install-git-hooks.sh >/dev/null 2>&1 || true",
    "dev:backend": "cd backend && npx cross-env NODE_ENV=development node start.js",
    "prod:backend": "cd backend && npx cross-env NODE_ENV=production node start.js",
    "dev:frontend": "cd frontend && npx cross-env NODE_ENV=development npm run dev",
    "prod:frontend": "cd frontend && npx cross-env NODE_ENV=production npm run build && cd frontend && npx cross-env NODE_ENV=production PORT=2000 npm run start",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "prod:all": "concurrently \"npm run prod:frontend\" \"npm run prod:backend\"",
    "clean": "rm -rf frontend/.next frontend/out backend/node_modules frontend/node_modules",
    "emails:add": "node scripts/manage-approved-emails.js add",
    "emails:remove": "node scripts/manage-approved-emails.js remove",
    "emails:list": "node scripts/manage-approved-emails.js list",
    "emails:sync": "node scripts/manage-approved-emails.js sync",
    "keep-alive": "node scripts/keep-alive.js",
    "keep-alive-bg": "node scripts/keep-alive.js &",
    "test:e2e:playwright": "npx playwright test --config=playwright.config.js",
    "test:e2e:ui": "npx playwright test --ui --config=playwright.config.js",
    "mobile:build:web": "cd frontend && npm run build",
    "mobile:copy": "npx cap copy",
    "mobile:sync": "npx cap sync android",
    "mobile:open": "npx cap open android",
    "mobile:add:android": "npx cap add android",
    "mobile:bundle": "cd android && ./gradlew bundleRelease"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "braces": "^3.0.3",
    "postcss": "^8.5.13",
    "micromatch": "^4.0.8",
    "react-intersection-observer": "^9.16.0",
    "sonner": "^2.0.1",
    "elliptic": "^6.5.7",
    "semver": "^7.5.4",
    "cross-spawn": "^7.0.5",
    "nanoid": "^3.3.3",
    "cookie": "^0.7.0",
    "tar": "^7.4.3",
    "ip": "^2.0.1",
    "ws": "^8.17.1",
    "undici": "^6.19.2",
    "@tootallnate/once": "^3.0.1",
    "multer": "1.4.5-lts.1",
    "busboy": "^1.6.0",
    "dicer": "0.3.1",
    "google-gax": "^4.4.1",
    "protobufjs": "^7.2.4",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^8.0.7",
    "next": "^15.5.18"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.4",
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "@playwright/test": "^1.40.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "^6.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "typescript": "5.8.2"
  },
  "keywords": [
    "shaadi",
    "mantrana",
    "matrimony",
    "monorepo"
  ],
  "author": "Shaadi Mantrana Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^7.0.0",
    "@capacitor/device": "^7.0.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@react-email/components": "^0.3.3",
    "@react-email/html": "^0.0.11",
    "@react-email/render": "^1.1.4",
    "@shadcn/ui": "^0.0.4",
    "@studio-freight/lenis": "^1.0.42",
    "axios": "^1.12.2",
    "backblaze-b2": "^1.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "express": "^5.1.0",
    "framer-motion": "^12.23.9",
    "firebase": "^10.13.1",
    "lucide-react": "^0.525.0",
    "multer": "1.4.5-lts.1",
    "next": "^15.5.18",
    "nodemailer": "^8.0.7",
    "pino-loki": "^2.1.0",
    "puppeteer": "^24.15.0",
    "react-chat-elements": "^12.0.18",
    "react-day-picker": "^9.8.0",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^9.16.0",
    "react-tailwindcss-datepicker": "^2.0.0",
    "react-time-picker": "^7.0.0"
  }
}
