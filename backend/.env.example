# Environment (development, production)
NODE_ENV=development
PORT=4000
DATA_SOURCE=mongodb

# Frontend URLs for CORS
FRONTEND_URL=http://localhost:3000
FRONTEND_FALLBACK_URL=http://localhost:3000
PRODUCTION_FRONTEND_URL=

# API Configuration
API_BASE_URL=http://localhost:4000
PRODUCTION_API_URL=

# Database Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DATABASE_NAME=shaadimantra_dev

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration
EMAIL_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_FROM=your_support_email@domain.com
ENABLE_EMAIL=true
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_app_password
EMAIL_FROM_NAME=Shaadi Mantrana Support

# Backblaze B2 Cloud Storage Configuration
B2_KEY_ID=your_b2_key_id
B2_APP_KEY=your_b2_app_key
B2_BUCKET_ID=your_b2_bucket_id
B2_BUCKET_NAME=your_b2_bucket_name

# Rate Limiting
OTP_DAILY_LIMIT=50
OTP_SHORT_TERM_LIMIT=20
OTP_VERIFY_LIMIT=30

# Debug Mode
DEBUG_MODE=true

# Grafana Loki Configuration
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_PASSWORD=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK (Backend Auth)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# E2E / Playwright testing (non-production only)
# Phone number used for Playwright test bypass — never a real user number
E2E_TEST_PHONE_NUMBER=0000000000
