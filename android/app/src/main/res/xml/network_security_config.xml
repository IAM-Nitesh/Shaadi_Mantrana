<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config for Shaadi Mantrana.
  - Enforces HTTPS for all connections in release.
  - Allows cleartext only for localhost during debug builds (handled by Capacitor).
  Place this file at: android/app/src/main/res/xml/network_security_config.xml
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system CAs only — no user-installed CAs in production -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext for localhost only (Capacitor live-reload in dev) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
