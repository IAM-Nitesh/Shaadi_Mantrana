{
  "info": {
    "name": "Shaadi Mantra - Verified API Collection",
    "_postman_id": "shaadi-mantra-verified-001",
    "description": "Synchronized Postman collection with local dev helpers and corrected Chat routes. Targeted at http://localhost:5500.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5500" },
    { "key": "prodUrl", "value": "https://shaadi-mantrana.onrender.com" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "otp", "value": "" },
    { "key": "email", "value": "niteshkumar9591@gmail.com" },
    { "key": "userId", "value": "" },
    { "key": "userUuid", "value": "" },
    { "key": "connectionId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"email\": \"{{email}}\" }" },
            "url": { "raw": "{{baseUrl}}/api/auth/send-otp", "host": ["{{baseUrl}}"], "path": ["api","auth","send-otp"] }
          }
        },
        {
          "name": "Get Dev OTP (Local Only)",
          "request": {
            "method": "GET",
            "url": { 
              "raw": "{{baseUrl}}/api/auth/_dev/last-otp?email={{email}}", 
              "host": ["{{baseUrl}}"], 
              "path": ["api","auth","_dev","last-otp"],
              "query": [{ "key": "email", "value": "{{email}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.otp) {",
                  "  pm.collectionVariables.set('otp', res.otp);",
                  "  pm.test('Dev OTP fetched: ' + res.otp, () => pm.expect(true).to.be.true);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Verify OTP (login)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"email\": \"{{email}}\", \"otp\": \"{{otp}}\" }" },
            "url": { "raw": "{{baseUrl}}/api/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["api","auth","verify-otp"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.session) {",
                  "  pm.collectionVariables.set('accessToken', res.session.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.session.refreshToken);",
                  "}",
                  "if (res.success && res.user) {",
                  "  pm.collectionVariables.set('userId', res.user.userId);",
                  "  pm.collectionVariables.set('userUuid', res.user.userUuid);",
                  "}",
                  "pm.test('Login success', () => pm.expect(res.success).to.be.true);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Preapproved email check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/preapproved/check?email={{email}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","preapproved","check"],
              "query": [{ "key": "email", "value": "{{email}}" }]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"refreshToken\": \"{{refreshToken}}\" }" },
            "url": { "raw": "{{baseUrl}}/api/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh-token"] }
          }
        }
      ]
    },
    {
      "name": "Profiles",
      "item": [
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/profiles/me", "host": ["{{baseUrl}}"], "path": ["api","profiles","me"] }
          }
        },
        {
          "name": "Get profiles (discovery)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/profiles", "host": ["{{baseUrl}}"], "path": ["api","profiles"] }
          }
        },
        {
          "name": "Get profile by UUID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/profiles/uuid/{{userUuid}}", "host": ["{{baseUrl}}"], "path": ["api","profiles","uuid","{{userUuid}}"] }
          }
        }
      ]
    },
    {
      "name": "Chat & Connections",
      "item": [
        {
          "name": "Get user connections",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/connections", "host": ["{{baseUrl}}"], "path": ["api","connections"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.connections && res.connections.length > 0) {",
                  "  pm.collectionVariables.set('connectionId', res.connections[0]._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get chat history",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/chat/{{connectionId}}", "host": ["{{baseUrl}}"], "path": ["api","chat","{{connectionId}}"] }
          }
        },
        {
          "name": "Send chat message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{ \"message\": \"Hello from Postman!\" }" },
            "url": { "raw": "{{baseUrl}}/api/chat/{{connectionId}}", "host": ["{{baseUrl}}"], "path": ["api","chat","{{connectionId}}"] }
          }
        }
      ]
    }
  ]
}